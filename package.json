{
  "name": "aptos-docs-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prebuild": "pnpm build:middleware-matcher && pnpm build:middleware",
    "predev": "pnpm build:middleware-matcher && pnpm build:middleware --watch &",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "pnpm prebuild && astro build && pnpm build:generate-middleware-function",
    "build:middleware-matcher": "tsx ./scripts/generate-middleware-matcher.js",
    "build:middleware": "tsx ./scripts/generate-middleware.js",
    "build:generate-middleware-function": "tsx ./scripts/generate-middleware-function.js",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "prepush": "astro check --noSync",
    "sync": "astro sync",
    "lint": "pnpm run --parallel --filter='.' /^lint:*/",
    "lint:biome": "biome check .",
    "lint:prettier": "prettier --check \"**/*.astro\"",
    "format": "pnpm run --parallel --filter='.' /^format:*/",
    "format:biome": "biome check --fix .",
    "format:prettier": "prettier --write \"**/*.astro\"",
    "format:content": "remark \"src/content/**/*.{md,mdx}\" --output",
    "postinstall": "pnpm exec simple-git-hooks",
    "tools:audit-sidebar": "tsx scripts/audit-sidebar.ts",
    "tools:fix-i18n-links": "tsx ./scripts/fix-i18n-links/fix-i18n-links-launcher.cjs",
    "test": "vitest run",
    "test:mermaid": "vitest run tests/mermaid-rendering.test.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@aptos-labs/ai-chatbot-client": "^0.1.4",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/node": "^10.1.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.39.2",
    "@astrojs/starlight-docsearch": "^0.7.0",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@astrojs/vercel": "^10.0.6",
    "@firebase/app": "^0.14.12",
    "@firebase/auth": "^1.13.1",
    "@nanostores/react": "^1.1.0",
    "@octokit/core": "^7.0.6",
    "@octokit/graphql": "^9.0.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@scalar/workspace-store": "^0.49.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge": "^1.3.0",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.3.1",
    "astro-mermaid": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.14.0",
    "nanostores": "^1.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "starlight-image-zoom": "^0.14.1",
    "starlight-links-validator": "^0.24.0",
    "tailwindcss": "^4.3.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.1.1",
    "@biomejs/biome": "2.4.4",
    "@crowdin/cli": "^4.14.1",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@graphiql/toolkit": "^0.11.3",
    "@iconify-json/ph": "^1.2.2",
    "@readme/openapi-parser": "^6.1.1",
    "@scalar/api-client": "^3.6.1",
    "@scalar/snippetz": "^0.9.6",
    "@swc/core": "^1.15.33",
    "@tailwindcss/vite": "^4.3.0",
    "@types/gtag.js": "^0.0.20",
    "@types/node": "^22.19.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@vercel/node": "^5.7.15",
    "astro-embed": "^0.13.0",
    "astro-favicons": "^3.1.6",
    "astro-icon": "^1.1.5",
    "astro-seo-schema": "^6.0.0",
    "baseline-browser-mapping": "^2.10.28",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "graphiql": "^5.2.2",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "kleur": "^4.1.5",
    "mdast-util-to-string": "^4.0.0",
    "nano-staged": "^1.0.2",
    "openapi-types": "^12.1.3",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "satori-html": "^0.3.2",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "simple-git-hooks": "^2.13.1",
    "starlight-llms-txt": "^0.8.1",
    "starlight-openapi": "^0.25.1",
    "starlight-package-managers": "^0.12.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "vite": "^7.3.3",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "patchedDependencies": {
      "astro": "patches/astro.patch",
      "@astrojs/vercel": "patches/@astrojs__vercel.patch",
      "starlight-openapi@0.25.1": "patches/starlight-openapi@0.25.1.patch",
      "vite-plugin-monaco-editor@1.1.0": "patches/vite-plugin-monaco-editor@1.1.0.patch"
    },
    "overrides": {
      "h3": "^1.15.6",
      "path-to-regexp@^6": "^6.3.0",
      "minimatch@^10": "^10.2.1",
      "undici@^5||^6": "^6.24.0",
      "undici@^7": "^7.24.0",
      "lodash-es@^4": "^4.18.0",
      "ajv@^8": "^8.18.0",
      "svgo@^3": "^3.3.3",
      "svgo@^4": "^4.0.1",
      "tar@^7": "^7.5.11",
      "flatted": ">=3.4.0",
      "dompurify": "^3.4.0",
      "devalue": ">=5.6.4",
      "yauzl@^3": ">=3.2.1",
      "yaml@^2": ">=2.8.3",
      "smol-toml@^1": ">=1.6.1",
      "defu@^6": "^6.1.5",
      "protobufjs": "^7.5.5",
      "uuid@^11": "^11.1.1",
      "postcss": "^8.5.10",
      "fast-uri": "^3.1.2"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged",
    "pre-push": "pnpm prepush"
  },
  "nano-staged": {
    "*.{js,cjs,mjs,jsx,ts,mts,tsx,json}": [
      "biome check --fix --no-errors-on-unmatched"
    ],
    "*.astro": [
      "prettier --write"
    ],
    "src/content/**/*.mdx": [
      "remark --output --"
    ]
  }
}
