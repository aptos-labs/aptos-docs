{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "name": "io.aptoslabs/aptos-mcp",
  "title": "Aptos MCP",
  "description": "Model Context Protocol server that gives IDE assistants direct access to Aptos APIs, on-chain data, Move tooling, and Aptos developer documentation.",
  "websiteUrl": "https://aptos.dev/build/ai/aptos-mcp",
  "version": "latest",
  "repository": {
    "url": "https://github.com/aptos-labs/aptos-mcp",
    "source": "github"
  },
  "serverInfo": {
    "name": "io.aptoslabs/aptos-mcp",
    "version": "latest"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@aptos-labs/aptos-mcp",
      "transport": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@aptos-labs/aptos-mcp"]
      }
    }
  ],
  "capabilities": {
    "tools": { "listChanged": false },
    "resources": { "listChanged": false, "subscribe": false },
    "prompts": { "listChanged": false }
  },
  "documentation": {
    "overview": "https://aptos.dev/build/ai/aptos-mcp",
    "claude": "https://aptos.dev/build/ai/aptos-mcp/claude",
    "cursor": "https://aptos.dev/build/ai/aptos-mcp/cursor"
  }
}
