---
import { isOpenAPIV2ResponseWithExamples } from "starlight-openapi/libs/example";
import { isExamples } from "starlight-openapi/libs/example";
import { isResponseWithHeaders } from "starlight-openapi/libs/header";
import type { Operation } from "starlight-openapi/libs/operation";
import {
  getResponseMediaEntries,
  type Response,
  type Responses,
} from "starlight-openapi/libs/response";
import type { Schema } from "starlight-openapi/libs/schemas/schema";
import { isSchemaObject } from "starlight-openapi/libs/schemaObject";
import ContentPicker from "../ContentPicker.astro";
import Md from "../Md.astro";
import SchemaComponent from "../schema/Schema.astro";
import SchemaObject from "../schema/SchemaObject.astro";
import Section from "../Section.astro";

import ResponseExamples from "./ResponseExamples.astro";
import ResponseHeaders from "./ResponseHeaders.astro";

interface Props {
  name: keyof Responses;
  operation: Operation;
  response: Response;
  schema: Schema;
}

const { name, operation, response, schema } = Astro.props;

const mediaEntries = getResponseMediaEntries(schema, operation, response);
const isEmpty = mediaEntries.length === 0;
const hasMediaTypes = mediaEntries.some((e) => e.mediaType);
const singleEntry = !hasMediaTypes ? mediaEntries[0] : undefined;
---

<Section empty={isEmpty} title={name}>
  <Md text={response.description} slot="pre-panel" />
  {
    hasMediaTypes ? (
      <ContentPicker
        label="Select media type"
        labelSingle="Media type"
        types={mediaEntries.map((e) => e.mediaType).filter((t): t is string => t !== undefined)}
      >
        {mediaEntries.map((entry, index) => (
          <div data-openapi-content-type={entry.mediaType} hidden={index > 0} role="tabpanel">
            <SchemaComponent
              example={entry.example}
              examples={isExamples(entry.examples) ? entry.examples : undefined}
              schema={isSchemaObject(entry.schema) ? entry.schema : undefined}
            />
          </div>
        ))}
      </ContentPicker>
    ) : singleEntry?.schema ? (
      <SchemaObject schemaObject={singleEntry.schema} />
    ) : null
  }
  {
    isResponseWithHeaders(response) && (
      <ResponseHeaders headers={response.headers} slot="post-panel" />
    )
  }
  {
    isOpenAPIV2ResponseWithExamples(response) && (
      <ResponseExamples examples={response.examples} slot="post-panel" />
    )
  }
</Section>
