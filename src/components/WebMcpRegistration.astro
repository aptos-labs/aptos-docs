/**
 * Wires WebMCP tool registration onto every docs page.
 *
 * Astro compiles the imported `.ts` module alongside the rest of the bundle, so
 * the tool definitions are type-checked (see `src/scripts/webmcp-register.ts`
 * and the `ModelContext` types in `src/types/webmcp.d.ts`). On browsers
 * without `navigator.modelContext` the script is a silent no-op.
 */
---

<script>
  import "~/scripts/webmcp-register";
</script>
