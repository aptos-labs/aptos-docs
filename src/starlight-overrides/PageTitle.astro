---
import Default from "@astrojs/starlight/components/PageTitle.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import CopyPageButton from "~/components/CopyPageButton.astro";

const currentPath = Astro.url.pathname;
const t = Astro.props.t || Astro.locals.t;
---

<Breadcrumbs
  currentPath={currentPath}
  truncated
  useHomeIcon
  dynamicPrefixes={["move-reference", "rest-api"]}
  disableIntermediatePaths={["rest-api"]}
/>
<div class="page-title-row">
  <Default {...Astro.props}><slot /></Default>
  <CopyPageButton copyLabel={t("copyPage.copy")} copiedLabel={t("copyPage.copied")} />
</div>

<style>
  .page-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .page-title-row :global(h1) {
    flex: 1;
    min-width: 0;
  }

  .page-title-row :global(copy-page-button) {
    flex-shrink: 0;
    margin-top: 1.25rem;
  }

  @media (max-width: 30rem) {
    .page-title-row :global(.copy-label),
    .page-title-row :global(.copied-label) {
      display: none;
    }
  }
</style>
