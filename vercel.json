          "key": "Link",
          "value": "</llms.txt>; rel=\"describedby\"; type=\"text/plain\", </.well-known/api-catalog>; rel=\"api-catalog\"; type=\"application/linkset+json\", </rest-api>; rel=\"service-doc\"; type=\"text/html\"; title=\"Aptos REST API reference\", </aptos-spec.json>; rel=\"service-desc\"; type=\"application/json\"; title=\"Aptos REST API OpenAPI spec\", </.well-known/mcp/server-card.json>; rel=\"describedby\"; type=\"application/json\"; title=\"Aptos MCP Server Card\", </.well-known/agent-skills/index.json>; rel=\"describedby\"; type=\"application/json\"; title=\"Aptos Agent Skills index\", </.well-known/oauth-protected-resource>; rel=\"describedby\"; type=\"application/json\"; title=\"Aptos Faucet OAuth Protected Resource Metadata\", </.well-known/openid-configuration>; rel=\"describedby\"; type=\"application/json\"; title=\"Aptos Faucet OpenID Connect Discovery\", </.well-known/oauth-authorization-server>; rel=\"describedby\"; type=\"application/json\"; title=\"Aptos Faucet OAuth 2.0 Authorization Server Metadata\""
